SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEMINI_API_KEY=AIzaSy...

# Email Notifications (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=AtomQuest <noreply@atomquest.dev>

# Microsoft Teams Webhook (optional)
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Azure AD SSO
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
# Set to 'true' in development to bypass Azure token verification
AZURE_SSO_DEV_BYPASS=false

# Escalation Engine Thresholds (days)
ESCALATION_DAYS_1=3
ESCALATION_DAYS_2=6
ESCALATION_DAYS_3=9

# Cron Schedules (cron syntax, UTC)
# Default: 02:30 UTC = 08:00 IST
ESCALATION_CRON_SCHEDULE=30 2 * * *
# Default: 03:30 UTC = 09:00 IST
CHECKIN_REMINDER_CRON=30 3 * * *

# Set to 'true' to run escalation rules on server startup (dev only)
RUN_ESCALATION_ON_STARTUP=false

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
